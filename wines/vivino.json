{
  "recipe_shortcut": "vivino_wines",
  "list_type": "wines",
  "engine_version": 26,
  "title": "Vivino Wines",
  "description": "Retrieve the wines from page vivino",
  "urls": [
    "vivino.com",
    "https://vivino.com",
    "https://www.vivino.com"
  ],
  "headers": {
    "Accept-Language": "en-UK,en",
    "User-Agent": "Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_2) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/81.0.4044.113 Safari/537.36"
  },
  "autocomplete_steps": [
    {
      "command": "load",
      "url": "https://www.vivino.com/search/wines?q=$INPUT",
      "description": "Load the Vivino search page",
      "config": {
        "timeout": 1
      }
    },
    {
      "command": "store_attribute",
      "locator": "#search-page",
      "attribute_name": "data-preloaded-state",
      "output": {
        "name": "JSON"
      },
      "description": "Capture Vivino's embedded search payload"
    },
    {
      "command": "json_store_text",
      "input": "JSON",
      "locator": "search_results.matches.length",
      "output": {
        "name": "NUMBER_OF_RESULTS",
        "type": "int"
      },
      "description": "Count returned wine matches"
    },
    {
      "command": "json_store_text",
      "input": "JSON",
      "locator": "search_results.matches[$i].vintage.name",
      "output": {
        "name": "TITLE$i"
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$NUMBER_OF_RESULTS - 1",
          "step": 1
        }
      },
      "description": "Extract wine title from preloaded JSON"
    },
    {
      "command": "json_store_text",
      "input": "JSON",
      "locator": "search_results.matches[$i].vintage.wine.region.name",
      "output": {
        "name": "REGION$i"
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$NUMBER_OF_RESULTS - 1",
          "step": 1
        }
      },
      "description": "Extract wine region from preloaded JSON"
    },
    {
      "command": "json_store_text",
      "input": "JSON",
      "locator": "search_results.matches[$i].vintage.wine.region.country.name",
      "output": {
        "name": "COUNTRY$i"
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$NUMBER_OF_RESULTS - 1",
          "step": 1
        }
      },
      "description": "Extract wine country from preloaded JSON"
    },
    {
      "command": "store",
      "input": "$REGION$i, $COUNTRY$i",
      "output": {
        "name": "SUBTITLE$i"
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$NUMBER_OF_RESULTS - 1",
          "step": 1
        }
      },
      "description": "Compose subtitle from region and country"
    },
    {
      "command": "json_store_text",
      "input": "JSON",
      "locator": "search_results.matches[$i].vintage.image.variations.bottle_small",
      "output": {
        "name": "COVER_PATH$i"
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$NUMBER_OF_RESULTS - 1",
          "step": 1
        }
      },
      "description": "Extract wine cover path from preloaded JSON"
    },
    {
      "command": "store",
      "input": "https:$COVER_PATH$i",
      "output": {
        "name": "COVER$i"
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$NUMBER_OF_RESULTS - 1",
          "step": 1
        }
      },
      "description": "Make wine cover URLs absolute"
    },
    {
      "command": "json_store_text",
      "input": "JSON",
      "locator": "search_results.matches[$i].vintage.wine.winery.seo_name",
      "output": {
        "name": "WINERY_SEO$i"
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$NUMBER_OF_RESULTS - 1",
          "step": 1
        }
      },
      "description": "Extract winery SEO slug from preloaded JSON"
    },
    {
      "command": "json_store_text",
      "input": "JSON",
      "locator": "search_results.matches[$i].vintage.wine.seo_name",
      "output": {
        "name": "WINE_SEO$i"
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$NUMBER_OF_RESULTS - 1",
          "step": 1
        }
      },
      "description": "Extract wine SEO slug from preloaded JSON"
    },
    {
      "command": "json_store_text",
      "input": "JSON",
      "locator": "search_results.matches[$i].vintage.wine.id",
      "output": {
        "name": "WINE_ID$i",
        "show": false
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$NUMBER_OF_RESULTS - 1",
          "step": 1
        }
      },
      "description": "Extract wine ID from preloaded JSON"
    },
    {
      "command": "store",
      "input": "https://www.vivino.com/$WINERY_SEO$i-$WINE_SEO$i/w/$WINE_ID$i",
      "output": {
        "name": "URL$i",
        "show": true
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$NUMBER_OF_RESULTS - 1",
          "step": 1
        }
      },
      "description": "Build canonical Vivino detail URLs"
    }
  ],
  "url_steps": [
    {
      "command": "load",
      "url": "$INPUT",
      "config": {
        "js": true,
        "timeout": 2
      },
      "description": "Load the url of the wine"
    },
    {
      "command": "store_url",
      "output": {
        "name": "URL"
      },
      "description": "Saves the URL of the detail"
    },
    {
      "command": "store_text",
      "locator": "title",
      "output": {
        "name": "WINERY",
        "type": "string",
        "show": true
      },
      "description": "Saves the winery of the wine"
    },
    {
      "command": "regex",
      "input": "$WINERY",
      "expression": "[^\\|]*",
      "output": {
        "name": "TITLE",
        "type": "string",
        "show": true
      },
      "description": "Applies a regular expression to get just the title"
    },
    {
      "command": "store",
      "input": "$TITLE",
      "output": {
        "name": "WINERY",
        "type": "string",
        "show": true
      },
      "description": ""
    },
    {
      "command": "store_text",
      "locator": "*[class*='vintage']",
      "output": {
        "name": "STYLE_TEXT",
        "type": "string",
        "show": false
      },
      "description": "Gets text from vintage element"
    },
    {
      "command": "regex",
      "input": "$STYLE_TEXT",
      "expression": "(\\d{4})",
      "output": {
        "name": "STYLE",
        "type": "string",
        "show": true
      },
      "description": "Extracts only the year (e.g. 2020) and stores as STYLE"
    },
    {
      "command": "store_text",
      "locator": "[class^=vivinoRating_averageValue]",
      "output": {
        "name": "RATING_RAW"
      },
      "description": "Gets the rating text with comma (e.g. 3,7)"
    },
    {
      "command": "regex",
      "input": "$RATING_RAW",
      "expression": "^([^,]*)",
      "output": {
        "name": "RATING_LEFT"
      },
      "description": "Extracts left part before comma"
    },
    {
      "command": "regex",
      "input": "$RATING_RAW",
      "expression": "(?<=,)(.*)",
      "output": {
        "name": "RATING_RIGHT"
      },
      "description": "Extracts right part after comma"
    },
    {
      "command": "store",
      "input": "$RATING_LEFT.$RATING_RIGHT",
      "output": {
        "name": "RATING",
        "type": "float",
        "show": true
      },
      "description": "Combines both parts with dot (3.7)"
    },
    {
      "command": "store_text",
      "locator": "*[class*='purchaseAvailability__currentPrice']",
      "output": {
        "name": "PRICE_TEXT",
        "type": "string",
        "show": false
      },
      "description": "Gets the price text (e.g. 6,50 €)"
    },
    {
      "command": "regex",
      "input": "$PRICE_TEXT",
      "expression": "(\\d+)[,.]",
      "output": {
        "name": "PRICE_INT"
      },
      "description": "Extracts integer part of price"
    },
    {
      "command": "regex",
      "input": "$PRICE_TEXT",
      "expression": "[,.](\\d+)",
      "output": {
        "name": "PRICE_DEC"
      },
      "description": "Extracts decimal part of price"
    },
    {
      "command": "store",
      "input": "$PRICE_INT.$PRICE_DEC",
      "output": {
        "name": "PRICE",
        "type": "float",
        "show": true
      },
      "description": "Combines integer and decimal with dot separator"
    },
    {
      "command": "store_text",
      "locator": "a[href*='/grapes/']",
      "output": {
        "name": "GRAPES",
        "type": "string",
        "show": true
      },
      "description": "Field: Type of grape"
    },
    {
      "command": "store_text",
      "locator": "table[class*='wineFacts__wineFacts'] tr[data-testid='wineFactRow']:nth-child(4) td[class*='wineFacts__fact'] a",
      "output": {
        "name": "VINTAGE",
        "type": "string",
        "show": true
      },
      "description": "Field: Saves the wine style as VINTAGE from wineFacts table row 4"
    },
    {
      "command": "store_text",
      "locator": "a[href*='/wine-countries/'], a[href*='/countries/'], *[class*='country'] a, *[data-testid*='country']",
      "output": {
        "name": "COUNTRY",
        "type": "string",
        "show": true
      },
      "description": "Saves the country"
    },
    {
      "command": "store_text",
      "locator": "a[href*='/wine-regions/']",
      "output": {
        "name": "PLACE",
        "type": "string",
        "show": true
      },
      "description": "Saves the description"
    },
    {
      "command": "store",
      "input": "$COUNTRY, $PLACE",
      "output": {
        "name": "REGION",
        "type": "string",
        "show": true
      },
      "description": "Field: Saves the region"
    },
    {
      "command": "store_attribute",
      "locator": "picture img",
      "attribute_name": "src",
      "output": {
        "name": "COVER"
      },
      "description": "Saves the image"
    },
    {
      "command": "store",
      "input": "https:$COVER",
      "output": {
        "name": "COVER",
        "type": "string",
        "show": true
      },
      "description": "Field: Add url param to the cover"
    },
    {
      "command": "store_text",
      "locator": "[class^=wineFacts__wineFacts] tr:last-child [class^=wineFacts__fact] span",
      "output": {
        "name": "DESCRIPTION",
        "type": "string",
        "show": true
      },
      "description": "Saves the description"
    },
    {
      "command": "store",
      "input": "$URL",
      "output": {
        "name": "URL_SALE"
      },
      "description": "Field: Saves the url to sale the product"
    }
  ]
}
