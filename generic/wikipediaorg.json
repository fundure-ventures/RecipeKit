{
  "recipe_shortcut": "wikipediaorg",
  "list_type": "generic",
  "engine_version": 26,
  "title": "Wikipedia.org",
  "description": "Retrieve generic articles from Wikipedia",
  "urls": [
    "https://wikipedia.org",
    "https://www.wikipedia.org",
    "https://en.wikipedia.org",
    "https://es.wikipedia.org",
    "https://fr.wikipedia.org",
    "https://de.wikipedia.org",
    "https://it.wikipedia.org",
    "https://hi.wikipedia.org",
    "https://pt.wikipedia.org",
    "https://ru.wikipedia.org",
    "https://ja.wikipedia.org",
    "https://zh.wikipedia.org",
    "https://pl.wikipedia.org",
    "https://nl.wikipedia.org",
    "https://ar.wikipedia.org"
  ],
  "headers": {
    "Accept-Language": "en-UK,en",
    "User-Agent": "Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_2) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/81.0.4044.113 Safari/537.36"
  },
  "languages_available": [
    "en",
    "es",
    "fr",
    "de",
    "it",
    "hi",
    "pt",
    "ru",
    "ja",
    "zh",
    "pl",
    "nl",
    "ar"
  ],
  "regions_available": [
    "US",
    "ES",
    "FR",
    "DE",
    "IT",
    "IN",
    "PT",
    "BR",
    "RU",
    "JP",
    "CN",
    "PL",
    "NL",
    "SA"
  ],
  "language_default": "en",
  "region_default": "US",
  "autocomplete_steps": [
    {
      "command": "url_encode",
      "input": "$INPUT",
      "output": {
        "name": "QUERY",
        "show": false
      },
      "description": "Encode the search term for the Wikipedia OpenSearch API"
    },
    {
      "command": "api_request",
      "url": "https://$SYSTEM_LANGUAGE.wikipedia.org/w/api.php?action=opensearch&search=$QUERY&limit=8&namespace=0&format=json&origin=*",
      "config": {
        "method": "GET",
        "headers": {
          "Api-User-Agent": "Listy RecipeKit/1.0 (https://github.com/listy-is/RecipeKit)"
        }
      },
      "output": {
        "name": "SEARCH_RESULTS",
        "show": false
      },
      "description": "Search Wikipedia articles with OpenSearch"
    },
    {
      "command": "json_count",
      "input": "SEARCH_RESULTS",
      "locator": "[1]",
      "output": {
        "name": "RESULT_COUNT",
        "show": false
      },
      "description": "Count the number of autocomplete results"
    },
    {
      "command": "json_store_text",
      "input": "SEARCH_RESULTS",
      "locator": "[1].[$i]",
      "output": {
        "name": "TITLE$i",
        "show": true
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$RESULT_COUNT - 1",
          "step": 1
        }
      },
      "description": "Extract autocomplete titles"
    },
    {
      "command": "json_store_text",
      "input": "SEARCH_RESULTS",
      "locator": "[2].[$i]",
      "output": {
        "name": "SUBTITLE$i",
        "show": true
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$RESULT_COUNT - 1",
          "step": 1
        }
      },
      "description": "Extract autocomplete descriptions"
    },
    {
      "command": "json_store_text",
      "input": "SEARCH_RESULTS",
      "locator": "[3].[$i]",
      "output": {
        "name": "URL$i",
        "show": true
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$RESULT_COUNT - 1",
          "step": 1
        }
      },
      "description": "Extract autocomplete URLs"
    },
    {
      "command": "store",
      "input": "https://$SYSTEM_LANGUAGE.wikipedia.org/static/favicon/wikipedia.ico",
      "output": {
        "name": "COVER$i",
        "show": true
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$RESULT_COUNT - 1",
          "step": 1
        }
      },
      "description": "Use the Wikipedia icon as autocomplete thumbnail"
    }
  ],
  "url_steps": [
    {
      "command": "regex",
      "input": "$INPUT",
      "expression": "https?:\\/\\/([^\\/]+)\\/wiki\\/[^?#]+",
      "output": {
        "name": "WIKI_HOST",
        "show": false
      },
      "description": "Extract the Wikipedia host from the article URL"
    },
    {
      "command": "regex",
      "input": "$INPUT",
      "expression": "https?:\\/\\/[^\\/]+\\/wiki\\/([^?#]+)",
      "output": {
        "name": "PAGE_KEY",
        "show": false
      },
      "description": "Extract the article key from the Wikipedia URL"
    },
    {
      "command": "api_request",
      "url": "https://$WIKI_HOST/api/rest_v1/page/summary/$PAGE_KEY",
      "config": {
        "method": "GET",
        "headers": {
          "Api-User-Agent": "Listy RecipeKit/1.0 (https://github.com/listy-is/RecipeKit)"
        }
      },
      "output": {
        "name": "PAGE_SUMMARY",
        "show": false
      },
      "description": "Fetch the article summary from Wikipedia's REST API"
    },
    {
      "command": "json_store_text",
      "input": "PAGE_SUMMARY",
      "locator": "title",
      "output": {
        "name": "TITLE",
        "show": true
      },
      "description": "Extract the article title"
    },
    {
      "command": "json_store_text",
      "input": "PAGE_SUMMARY",
      "locator": "description",
      "output": {
        "name": "SUMMARY",
        "show": true
      },
      "description": "Extract the short Wikipedia description"
    },
    {
      "command": "json_store_text",
      "input": "PAGE_SUMMARY",
      "locator": "extract",
      "output": {
        "name": "DESCRIPTION",
        "show": true
      },
      "description": "Extract the article summary text"
    },
    {
      "command": "json_store_text",
      "input": "PAGE_SUMMARY",
      "locator": "thumbnail.source",
      "output": {
        "name": "COVER",
        "show": true
      },
      "description": "Extract the article thumbnail as a fallback cover"
    },
    {
      "command": "json_store_text",
      "input": "PAGE_SUMMARY",
      "locator": "originalimage.source",
      "output": {
        "name": "COVER",
        "show": true
      },
      "description": "Prefer the original article image when available"
    },
    {
      "command": "json_store_text",
      "input": "PAGE_SUMMARY",
      "locator": "timestamp",
      "output": {
        "name": "DATE",
        "type": "date",
        "show": true
      },
      "description": "Extract the last updated timestamp"
    },
    {
      "command": "store",
      "input": "$INPUT",
      "output": {
        "name": "URL",
        "show": true
      },
      "description": "Keep the original article URL as a fallback"
    },
    {
      "command": "json_store_text",
      "input": "PAGE_SUMMARY",
      "locator": "content_urls.desktop.page",
      "output": {
        "name": "URL",
        "show": true
      },
      "description": "Prefer the canonical desktop article URL"
    },
    {
      "command": "store",
      "input": "https://$WIKI_HOST/static/favicon/wikipedia.ico",
      "output": {
        "name": "FAVICON",
        "show": true
      },
      "description": "Store the Wikipedia favicon"
    }
  ]
}
