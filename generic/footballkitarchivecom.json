{
  "recipe_shortcut": "footballkitarchivecom",
  "list_type": "generic",
  "engine_version": 26,
  "title": "Footballkitarchive.com",
  "description": "Retrieve generic from footballkitarchive.com",
  "urls": [
    "https://footballkitarchive.com",
    "https://www.footballkitarchive.com"
  ],
  "headers": {
    "Accept-Language": "en-UK,en",
    "User-Agent": "Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_2) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/81.0.4044.113 Safari/537.36"
  },
  "autocomplete_steps": [
    {
      "command": "url_encode",
      "input": "$INPUT 2025-26 Home site:footballkitarchive.com",
      "output": {
        "name": "QUERY"
      }
    },
    {
      "command": "load",
      "url": "https://html.duckduckgo.com/html/?q=$QUERY",
      "description": "Search Football Kit Archive pages through DuckDuckGo"
    },
    {
      "command": "store_text",
      "locator": "a.result__a[href*='footballkitarchive']",
      "output": {
        "name": "FULL_TITLE1"
      },
      "description": "Extract the first matching result title"
    },
    {
      "command": "regex",
      "input": "$FULL_TITLE1",
      "expression": "^(.*?)\\s+\\d{4}-\\d{2}\\s+.+?\\s+Kit(?:\\s+-\\s+Football Kit Archive)?$",
      "output": {
        "name": "TITLE1"
      },
      "description": "Extract the team name from the result title"
    },
    {
      "command": "regex",
      "input": "$FULL_TITLE1",
      "expression": "^.*?(\\d{4}-\\d{2}\\s+.+?)\\s+Kit(?:\\s+-\\s+Football Kit Archive)?$",
      "output": {
        "name": "SUBTITLE1"
      },
      "description": "Extract the season and kit type"
    },
    {
      "command": "store_attribute",
      "locator": "a.result__a[href*='footballkitarchive']",
      "attribute_name": "href",
      "output": {
        "name": "URL1"
      },
      "description": "Store the result URL"
    },
    {
      "command": "store",
      "input": "https://www.footballkitarchive.com/favicon.ico",
      "output": {
        "name": "COVER1"
      },
      "description": "Provide a stable cover placeholder for search results"
    }
  ],
  "url_steps": [
    {
      "command": "load",
      "url": "$INPUT",
      "config": {
        "js": true,
        "timeout": 5000
      },
      "description": "Load kit detail page"
    },
    {
      "command": "store_url",
      "output": {
        "name": "URL"
      },
      "description": "Save URL"
    },
    {
      "command": "store_text",
      "locator": "h1",
      "output": {
        "name": "TITLE",
        "type": "string",
        "show": true
      },
      "description": "Extract kit title from h1"
    },
    {
      "command": "store_attribute",
      "locator": "meta[property='og:description']",
      "attribute_name": "content",
      "output": {
        "name": "DESCRIPTION",
        "type": "string",
        "show": true
      },
      "description": "Extract description from og:description"
    },
    {
      "command": "store_attribute",
      "locator": "link[rel='icon']",
      "attribute_name": "href",
      "output": {
        "name": "FAVICON",
        "type": "string",
        "show": true
      },
      "description": "Extract favicon"
    },
    {
      "command": "store_attribute",
      "locator": "meta[property='og:image']",
      "attribute_name": "content",
      "output": {
        "name": "COVER",
        "type": "string",
        "show": true
      },
      "description": "Extract cover image from og:image"
    }
  ]
}
