{
  "recipe_shortcut": "fragranticacom",
  "list_type": "generic",
  "engine_version": 26,
  "title": "Perfumes and Colognes Magazine, Perfume Reviews and Online Community—Fragrantica.com",
  "description": "Retrieve generic from fragrantica.com",
  "urls": [
    "https://fragrantica.*",
    "https://www.fragrantica.*"
  ],
  "headers": {
    "Accept-Language": "en-US,en;q=0.9",
    "User-Agent": "Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_2) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
  },
  "autocomplete_steps": [
    {
      "command": "api_request",
      "url": "https://fgvi612dfz-dsn.algolia.net/1/indexes/*/queries?x-algolia-agent=Algolia%20for%20JavaScript%20(4.26.0)%3B%20Browser%20(lite)%3B%20instantsearch.js%20(4.92.1)%3B%20Vue%20(3.5.31)%3B%20Vue%20InstantSearch%20(4.24.3)%3B%20JS%20Helper%20(3.28.1)&x-algolia-api-key=YjhjZTBiODRmNGVlYjBkYzYyNWRlMDA5NTU0MjY4NjVhOTZhZGUyMjg1NGFhMjk2MTkyOTk5NzYxMWZkZjI3ZnZhbGlkVW50aWw9MTc4MDQ4MTI2NA%3D%3D&x-algolia-application-id=FGVI612DFZ",
      "config": {
        "method": "POST",
        "headers": {
          "Content-Type": "application/x-www-form-urlencoded",
          "Origin": "https://www.fragrantica.com",
          "Referer": "https://www.fragrantica.com/"
        },
        "body": "{\"requests\":[{\"indexName\":\"fragrantica_perfumes\",\"params\":\"attributesToRetrieve=%5B%22naslov%22%2C%22dizajner%22%2C%22godina%22%2C%22id%22%2C%22slug%22%2C%22thumbnail%22%2C%22spol%22%2C%22num_reviews.EN%22%5D&highlightPostTag=__%2Fais-highlight__&highlightPreTag=__ais-highlight__&hitsPerPage=60&maxValuesPerFacet=100&page=0&query=$INPUT\"}]}"
      },
      "output": {
        "name": "API_RESPONSE"
      },
      "description": "Fetch search results from Fragrantica Algolia API"
    },
    {
      "command": "json_count",
      "input": "$API_RESPONSE",
      "locator": "results[0].hits",
      "output": {
        "name": "RESULT_COUNT"
      },
      "description": "Count the number of perfume search results"
    },
    {
      "command": "json_store_text",
      "input": "$API_RESPONSE",
      "locator": "results[0].hits[$i].naslov",
      "output": {
        "name": "TITLE$i",
        "show": true
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$RESULT_COUNT - 1",
          "step": 1
        }
      },
      "description": "Extract perfume titles"
    },
    {
      "command": "json_store_text",
      "input": "$API_RESPONSE",
      "locator": "results[0].hits[$i].dizajner",
      "output": {
        "name": "SUBTITLE$i",
        "show": true
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$RESULT_COUNT - 1",
          "step": 1
        }
      },
      "description": "Extract designer names"
    },
    {
      "command": "json_store_text",
      "input": "$API_RESPONSE",
      "locator": "results[0].hits[$i].slug",
      "output": {
        "name": "SLUG$i"
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$RESULT_COUNT - 1",
          "step": 1
        }
      },
      "description": "Extract perfume slug"
    },
    {
      "command": "json_store_text",
      "input": "$API_RESPONSE",
      "locator": "results[0].hits[$i].id",
      "output": {
        "name": "ID$i"
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$RESULT_COUNT - 1",
          "step": 1
        }
      },
      "description": "Extract perfume id"
    },
    {
      "command": "store",
      "input": "https://www.fragrantica.com/perfume/$SLUG$i-$ID$i.html",
      "output": {
        "name": "URL$i",
        "show": true
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$RESULT_COUNT - 1",
          "step": 1
        }
      },
      "description": "Build absolute perfume URLs"
    },
    {
      "command": "json_store_text",
      "input": "$API_RESPONSE",
      "locator": "results[0].hits[$i].thumbnail",
      "output": {
        "name": "COVER$i",
        "show": true
      },
      "config": {
        "loop": {
          "index": "i",
          "from": 0,
          "to": "$RESULT_COUNT - 1",
          "step": 1
        }
      },
      "description": "Extract thumbnail images"
    }
  ],
  "url_steps": [
    {
      "command": "load",
      "url": "$INPUT",
      "config": {
        "js": true,
        "timeout": 10000
      },
      "description": "Load perfume detail page"
    },
    {
      "command": "store_url",
      "output": {
        "name": "URL"
      },
      "description": "Save URL"
    },
    {
      "command": "store_attribute",
      "locator": "meta[property='og:title']",
      "attribute_name": "content",
      "output": {
        "name": "TITLE",
        "type": "string",
        "show": true
      },
      "description": "Extract title from og:title"
    },
    {
      "command": "store_attribute",
      "locator": "meta[property='og:description']",
      "attribute_name": "content",
      "output": {
        "name": "DESCRIPTION",
        "type": "string",
        "show": true
      },
      "description": "Extract description from og:description"
    },
    {
      "command": "store_attribute",
      "locator": "link[rel='icon']",
      "attribute_name": "href",
      "output": {
        "name": "FAVICON_RAW",
        "type": "string",
        "show": false
      },
      "description": "Extract favicon href"
    },
    {
      "command": "store",
      "input": "https://www.fragrantica.com$FAVICON_RAW",
      "output": {
        "name": "FAVICON",
        "type": "string",
        "show": true
      },
      "description": "Make favicon URL absolute"
    },
    {
      "command": "store_attribute",
      "locator": "meta[property='og:image']",
      "attribute_name": "content",
      "output": {
        "name": "COVER",
        "type": "string",
        "show": true
      },
      "description": "Extract cover image from og:image"
    }
  ]
}
